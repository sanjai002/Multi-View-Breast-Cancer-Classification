# =============================================================================
# Datasets — never belong in git.
#
# This repo has a public GitHub remote, so anything committed here is published.
# Raw imaging data is hundreds of GB and, more importantly, is patient data.
# =============================================================================

# NLBS (Phase 1, retired) — guards kept in case the data is restored locally.
/normal/
/abnormal/
/False Positive/
/normal.7z
NLBSD_Metadata.csv

# CBIS-DDSM or any bulk archive dropped into a phase folder.
*/archive/
*/archive.zip
*.7z



# =============================================================================
# Phase 2 — regenerable artifacts.
#
# outputs/ holds the transition buffer, checkpoints, logs and result CSVs. It is
# all reproducible by rerunning the pipeline, and the buffer embeds patient-level
# records, so it stays out of git.
# =============================================================================
Phase2_RL/outputs/
Phase2_RL/checkpoints/*.pth
Phase2_RL/tensorboard/
Phase2_RL/logs/

# =============================================================================
# Phase 1 (retired 2026-07-21) — guards retained in case the tree is restored
# from branch archive/phase1-dl.
# =============================================================================
Phase1_DL/outputs/
Phase1_DL/checkpoints/*.pth
Phase1_DL/tensorboard/
Phase1_DL/logs/
Phase1_DL/colab_bundle/
Phase1_DL/data/metadata.csv

# =============================================================================
# Python
# =============================================================================
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
.ipynb_checkpoints/


Phase1_DL/outputs/metadata_*.csv
Phase1_DL/outputs/train.pid
Phase1_DL/outputs/train_group.pid
Phase1_DL/checkpoints/*.pth
Phase1_DL/tensorboard/
Phase1_DL/logs/
Phase1_DL/colab_bundle/
colab_bundle/

# Patient-level data (identifiable Patient_ID + Age + diagnosis) — never push
# to a cloud remote without explicitly confirming NLBS's data-use terms allow
# it. Code/plots/reports stay in the repo; per-patient label tables do not.
Phase1_DL/data/metadata.csv
Phase1_DL/outputs/patient_manifest.csv
Phase1_DL/outputs/prediction_probabilities.csv
Phase1_DL/outputs/patient_predictions.csv
Phase1_DL/outputs/patient_feature_index.csv
Phase1_DL/outputs/image_feature_index.csv
NLBSD_Metadata.csv

